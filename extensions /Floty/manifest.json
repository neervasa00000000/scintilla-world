{
  "manifest_version": 3,
  "name": "Floty",
  "version": "2.0.4",
  "description": "Floating bubble: send text from any tab to your AI chat tab and get the reply back — no API keys in the extension.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Floty"
  },
  "permissions": ["storage", "clipboardWrite", "clipboardRead", "tabs"],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/relay.js", "js/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
